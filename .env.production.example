# Copy this file to .env on the EC2 server and fill in the values.
# Never commit the real .env to git.

DOMAIN=inanhxink.com
NODE_ENV=production   # legacy env name; Go backend treats env vars as externally provided
DB_PASSWORD=change_me_to_a_strong_password
VITE_API_URL=https://inanhxink.com
# Sepay payment gateway — QR keychain orders
SEPAY_API_KEY=your_sepay_api_key
SEPAY_ACCOUNT_NO=your_qr_account_number
SEPAY_ACCOUNT_NAME=YOUR FULL NAME
SEPAY_BANK=ACB

# Sepay payment gateway — product orders (separate bank account)
SEPAY_PRODUCT_ACCOUNT_NO=your_product_account_number
SEPAY_PRODUCT_ACCOUNT_NAME=YOUR BUSINESS NAME
SEPAY_PRODUCT_BANK=MBBank

# Docker image tag (optional, defaults to "latest")
# Set to a specific commit hash for rollback: IMAGE_TAG=sha-abc1234
IMAGE_TAG=latest

# S3-compatible object storage (Viettel IDC)
S3_ENDPOINT=https://s3-north1.viettelidc.com.vn
S3_REGION=north1
S3_BUCKET=inanhxink-prod
VITE_S3_BUCKET=inanhxink-prod
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key

# Sentry error monitoring (Node backend only; Go backend currently does not send Sentry events)
SENTRY_DSN=sentry_dsn_for_backend

# Admin credentials (used by db:init to seed the admin user)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password