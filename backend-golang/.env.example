# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=mysecretpassword
DB_NAME=mydb

# Server
PORT=3001
NODE_ENV=development
DOMAIN=inanhxink.com

# S3 / Object storage
S3_ENDPOINT=https://s3.your-provider.com
S3_REGION=north1
S3_BUCKET=inanhxink-prod
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# CDN (leave empty in dev to use raw S3 URLs)
CDN_BASE_URL=https://cdn.inanhxink.com

# Admin auth
JWT_SECRET=change-this-in-production

# Payments (Sepay)
SEPAY_API_KEY=your-sepay-api-key
SEPAY_ACCOUNT_NO=your-account-number
SEPAY_BANK=MBBank
